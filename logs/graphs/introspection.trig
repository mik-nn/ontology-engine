    <https://ontologist.ai/ns/oe/module/github-skills-excalidraw-diagram-generator-scripts-split-excalidraw-library-py> oe:absolutePath "/home/mikz/ontology-engine/.github/skills/excalidraw-diagram-generator/scripts/split-excalidraw-library.py" ;
