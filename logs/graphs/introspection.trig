      ]
    },
    
    {
      "@id": "pz:HawaiianHalf001",
      "@type": "PizzaDiv", 
      "label": { "@value": "Hawaiian Half", "@language": "en" },
      "comment": { "@value": "One half of the pizza with Hawaiian-style toppings", "@language": "en" },
      "configurations": "pz:HawaiianConfig001"
    },
    
    {
