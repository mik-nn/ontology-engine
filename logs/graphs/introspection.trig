    <https://ontologist.ai/ns/oe/module/planning-plan-executor-py> oe:absolutePath "/home/mikz/ontology-engine/planning/plan_executor.py" ;
        oe:dependsOn build:__future__,
            build:cli,
            build:dataclasses,
            build:datetime,
            build:execution,
            build:pathlib,
            build:rdflib,
            build:re,
            build:time,
            build:typing,
            build:uuid,
            <https://ontologist.ai/ns/oe/module/context-context-builder>,
            <https://ontologist.ai/ns/oe/module/context-context-pruner>,
            <https://ontologist.ai/ns/oe/module/pipeline-git-client>,
            <https://ontologist.ai/ns/oe/module/pipeline-metrics>,
            <https://ontologist.ai/ns/oe/module/planning-task-decomposer>,
            <https://ontologist.ai/ns/oe/module/planning-task-planner>,
            <https://ontologist.ai/ns/oe/module/planning-task-type-registry>,
            <https://ontologist.ai/ns/oe/module/storage-graph-store>,
            <https://ontologist.ai/ns/oe/module/storage-id-manager> ;
        oe:description """Stage 7 — Plan Executor.

Iterates a PlanSpec in topological order. For each subtask:
  1. Build context packet (ContextBuilder + ContextPruner)
  2. Dispatch to executor stub (Stage 8 will replace stubs with real LLM/git calls)
  3. Write ExecutionResult to graph
  4. Validate with RuleEngine
  5. Update subtask status and emit event

Executor stubs:
  - llm       → logs context + placeholder result
  - reasoning → runs SPARQL/RuleEngine queries, no LLM
  - git_client → stubs a commit (Stage 8 """ ;
        oe:fileExt ".py" ;
        oe:fileName "plan_executor.py" ;
        oe:filePath "planning/plan_executor.py" ;
        oe:fileSizeBytes 23400 .
}

