<https://ontologist.ai/ns/oe/module/kilo-node-modules-shebang-regex-readme-md/interior> {
    <https://ontologist.ai/ns/oe/module/kilo-node-modules-shebang-regex-readme-md> db:content """# shebang-regex [![Build Status](https://travis-ci.org/sindresorhus/shebang-regex.svg?branch=master)](https://travis-ci.org/sindresorhus/shebang-regex)

> Regular expression for matching a [shebang](https://en.wikipedia.org/wiki/Shebang_(Unix)) line


## Install

```
$ npm install shebang-regex
```


## Usage

```js
const shebangRegex = require('shebang-regex');

const string = '#!/usr/bin/env node\\nconsole.log("unicorns");';

shebangRegex.test(string);
//=> true

shebangRegex.exec(string)[0];
/""" ;
        db:title "readme" .
}

