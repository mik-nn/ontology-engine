        db:id "event_schema" ;
        db:license "CC-BY-4.0" ;
        db:title "Event Log Schema" ;
        db:transformer "human" ;
        db:type "reference" ;
        db:version "1.1.0" ;
        oe:fileExt ".md" ;
        oe:fileName "event-schema.md" ;
        oe:filePath "docs/logs/event-schema.md" ;
        oe:fileSizeBytes 3881 .
}

