<https://ontologist.ai/ns/oe/module/kilo-node-modules-which-readme-md/interior> {
    <https://ontologist.ai/ns/oe/module/kilo-node-modules-which-readme-md> db:content """# which

Like the unix `which` utility.

Finds the first instance of a specified executable in the PATH
environment variable.  Does not cache the results, so `hash -r` is not
needed when the PATH changes.

## USAGE

```javascript
var which = require('which')

// async usage
which('node', function (er, resolvedPath) {
  // er is returned if no "node" is found on the PATH
  // if it is found, then the absolute path to the exec is returned
})

// or promise
which('node').then(resolvedPath => { ... """ ;
        db:created "2024-04-20" ;
        db:id "README" ;
        db:title "README" ;
        db:type "plain-doc" ;
        db:version "0.1" .
}

