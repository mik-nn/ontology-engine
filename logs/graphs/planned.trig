    <https://ontologist.ai/ns/oe/module/planning-task-planner-py> oe:absolutePath "/home/mikz/ontology-engine/planning/task_planner.py" ;
        oe:dependsOn build:__future__,
            build:dataclasses,
            build:datetime,
            build:pathlib,
            build:rdflib,
            <https://ontologist.ai/ns/oe/module/planning-task-decomposer>,
            <https://ontologist.ai/ns/oe/module/storage-graph-store>,
            <https://ontologist.ai/ns/oe/module/storage-id-manager> ;
        oe:description """Stage 7 — Task Planner (no LLM).

Takes a SubtaskTree and produces a validated, topologically sorted Plan:
  1. Topological sort using Kahn's algorithm on dependsOn edges
  2. Executor assignment per subtask type (from rules, not LLM)
  3. Cycle detection (raises PlanningError if cycle found)
  4. SHACL validation of the Plan node
  5. Writes PlanGenerated event

Returns a PlanSpec ready for PlanExecutor.""" ;
        oe:fileExt ".py" ;
        oe:fileName "task_planner.py" ;
        oe:filePath "planning/task_planner.py" ;
        oe:fileSizeBytes 9636 .
}

