<https://ontologist.ai/ns/oe/module/kilo-node-modules-isexe-readme-md/interior> {
    <https://ontologist.ai/ns/oe/module/kilo-node-modules-isexe-readme-md> db:content """# isexe

Minimal module to check if a file is executable, and a normal file.

Uses `fs.stat` and tests against the `PATHEXT` environment variable on
Windows.

## USAGE

```javascript
var isexe = require('isexe')
isexe('some-file-name', function (err, isExe) {
  if (err) {
    console.error('probably file does not exist or something', err)
  } else if (isExe) {
    console.error('this thing can be run')
  } else {
    console.error('cannot be run')
  }
})

// same thing but synchronous, throws er""" ;
        db:created "2024-04-20" ;
        db:id "README" ;
        db:title "README" ;
        db:type "plain-doc" ;
        db:version "0.1" .
}

